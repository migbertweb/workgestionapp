# WorkApp — variables de entorno
# Copiar a .env y editar

NODE_ENV=production
PORT=3001
DB_PATH=/app/data/workapp.db

# JWT secret (cambiar en producción)
JWT_SECRET=workapp-dev-secret-change-in-production

# Admin seed (se crea al primer boot si no existe)
ADMIN_USER=admin
ADMIN_PASS=admin123

# Telegram notifications (Tier 1)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=